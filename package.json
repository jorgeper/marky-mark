{
  "name": "marky-mark",
  "private": true,
  "version": "0.4.0-alpha.3",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:web": "vite build --config vite.web.config.ts",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:web": "playwright test --config playwright.web.config.ts",
    "validate": "node scripts/validate.mjs",
    "release:prepare": "node scripts/release-prepare.mjs",
    "build:app": "tauri build --bundles app --config '{\"bundle\":{\"createUpdaterArtifacts\":false}}'",
    "clean:app": "bash scripts/deep-clean.sh",
    "install:app": "pkill -x marky-mark; rm -rf '/Applications/Marky Mark.app' && ditto 'src-tauri/target/release/bundle/macos/Marky Mark.app' '/Applications/Marky Mark.app' && open '/Applications/Marky Mark.app'",
    "licenses": "node scripts/licenses.mjs",
    "validate:quick": "node scripts/validate.mjs --quick",
    "build:app:fast": "tauri build --debug --bundles app --config '{\"bundle\":{\"createUpdaterArtifacts\":false}}'",
    "install:app:fast": "pkill -x marky-mark; rm -rf '/Applications/Marky Mark.app' && ditto 'src-tauri/target/debug/bundle/macos/Marky Mark.app' '/Applications/Marky Mark.app' && open '/Applications/Marky Mark.app'",
    "ship:local": "npm run validate:quick && npm run build:app:fast && npm run install:app:fast"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.0",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.36.0",
    "@lezer/highlight": "^1.2.3",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-fs": "^2.2.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "diff-match-patch": "^1.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-highlight": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "unified": "^11.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tauri-apps/cli": "^2.5.0",
    "@types/diff-match-patch": "^1.0.36",
    "@types/node": "^26.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^3.0.0"
  }
}
