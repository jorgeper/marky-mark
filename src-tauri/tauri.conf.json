{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Marky Mark",
  "version": "0.2.0-alpha.6",
  "identifier": "com.markimark.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Marky Mark",
        "width": 1150,
        "height": 820,
        "minWidth": 480,
        "minHeight": 320
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost https://asset.localhost data: blob:; font-src 'self' asset: https://asset.localhost data:; connect-src ipc: http://ipc.localhost; object-src 'none'; frame-src 'none'; base-uri 'none'; form-action 'none'",
      "devCsp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Editor",
        "mimeType": "text/markdown"
      }
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDczRkQzQkIwMzhGNjREQzIKUldUQ1RmWTRzRHY5YzNPc2pvVFlvTVdLMXJ2SEZDemZwSUlmN1VNbWNpVmptQjFKRG4xWHJQNGoK",
      "endpoints": ["https://github.com/jorgeper/marky-mark/releases/download/updater/latest.json"]
    }
  }
}
